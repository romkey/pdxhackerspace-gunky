{
  "name": "app",
  "private": "true",
  "scripts": {
    "build:css:compile": "npx sass ./app/assets/stylesheets/application.bootstrap.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "build:css:prefix": "npx postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
    "build:css": "npm run build:css:compile && npm run build:css:prefix",
    "watch:css": "npx nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"npm run build:css\""
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "sass": "^1.97.3"
  }
}
