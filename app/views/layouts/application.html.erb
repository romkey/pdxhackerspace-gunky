<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Gunky" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gunky">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script>
      (() => {
        const applyTheme = (event) => {
          document.documentElement.setAttribute("data-bs-theme", event.matches ? "dark" : "light")
        }

        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)")
        applyTheme(mediaQuery)
        mediaQuery.addEventListener("change", applyTheme)
      })()
    </script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100 bg-body-tertiary text-body">
    <nav class="navbar navbar-expand-lg bg-body border-bottom mb-4">
      <div class="container">
        <%= link_to "Gunky", root_path, class: "navbar-brand fw-bold" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "All Items", items_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "New Item", new_item_path, class: "nav-link" %>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Settings</a>
              <ul class="dropdown-menu">
                <li><%= link_to "Locations", settings_locations_path, class: "dropdown-item" %></li>
                <li><%= link_to "AI Agent", settings_agent_path, class: "dropdown-item" %></li>
                <li><%= link_to "Slack Member Cache", settings_slack_member_caches_path, class: "dropdown-item" %></li>
                <li><%= link_to "Thermal printer", settings_print_path, class: "dropdown-item" %></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container flex-grow-1">
      <% if flash[:notice] %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= flash[:notice] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= flash[:alert] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <footer class="mt-4 py-3 border-top text-center text-body-secondary small">
      <div class="container">
        <a href="https://github.com/romkey/pdxhackerspace-gunky" class="text-body-secondary text-decoration-none">Gunky</a>
        v<%= Gunky::VERSION %>
      </div>
    </footer>
  </body>
</html>
