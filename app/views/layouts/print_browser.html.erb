<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "Print" %> — Gunky</title>
    <style>
      :root {
        color-scheme: light;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 1rem;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        line-height: 1.4;
        color: #000;
        background: #e9ecef;
      }

      .print-browser-hint {
        max-width: 48rem;
        margin: 0 auto 1.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
        font-size: 0.9rem;
      }

      .print-browser-sheets {
        max-width: 56rem;
        margin: 0 auto;
      }

      .browser-print-sheet {
        background: #fff;
        padding: 1.5rem 1.75rem;
        margin-bottom: 1.5rem;
        border: 1px solid #adb5bd;
        border-radius: 0.25rem;
      }

      .browser-print-sheet h1 {
        margin: 0 0 1rem;
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.2;
      }

      .browser-print-photo {
        display: block;
        max-width: 100%;
        height: auto;
        max-height: 70vh;
        object-fit: contain;
        margin: 0 0 1.25rem;
      }

      .browser-print-meta {
        margin: 0;
        display: grid;
        grid-template-columns: 8rem 1fr;
        gap: 0.35rem 1rem;
        font-size: 0.95rem;
      }

      .browser-print-meta dt {
        margin: 0;
        font-weight: 600;
        color: #333;
      }

      .browser-print-meta dd {
        margin: 0;
      }

      @media print {
        body {
          background: #fff;
          padding: 0;
        }

        .print-browser-hint {
          display: none !important;
        }

        .browser-print-sheet {
          border: none;
          border-radius: 0;
          margin: 0;
          padding: 0.75rem 0;
          box-shadow: none;
        }

        .browser-print-sheet:not(.last-sheet) {
          page-break-after: always;
          break-after: page;
        }

        .browser-print-sheet.last-sheet {
          page-break-after: auto;
          break-after: auto;
        }

        .browser-print-photo {
          max-height: none;
        }
      }

      @page {
        margin: 12mm;
      }
    </style>
  </head>
  <body>
    <div class="print-browser-hint">
      <strong>Browser print</strong> — Use <kbd>Cmd+P</kbd> / <kbd>Ctrl+P</kbd>. Paper size and scaling are controlled in the print dialog (not fixed to receipt width).
    </div>
    <div class="print-browser-sheets">
      <%= yield %>
    </div>
  </body>
</html>
