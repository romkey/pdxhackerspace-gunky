<%# locals: (item:, print_setting:, last_receipt:) %>
<% photo_max = print_setting.paper_width_mm >= 80 ? 576 : 384 %>
<article class="thermal-receipt<%= " last-receipt" if last_receipt %>">
  <h1><%= item.display_description %></h1>

  <% if item.photo.attached? %>
    <%= image_tag url_for(item.photo.variant(resize_to_limit: [ photo_max, photo_max ])),
          class: "receipt-photo",
          alt: "" %>
  <% else %>
    <div class="receipt-photo-placeholder">No photo</div>
  <% end %>

  <div class="receipt-section">
    <div class="receipt-label">Location</div>
    <%= item.location.presence || "Not specified" %>
  </div>

  <div class="receipt-section">
    <div class="receipt-label">Winners / disposition</div>
    <% receipt_disposition_lines(item).each do |line| %>
      <div><%= line %></div>
    <% end %>
  </div>

  <div class="receipt-deadline">
    Pickup / action deadline:
    <% if item.pickup_deadline_date %>
      <%= item.pickup_deadline_date.strftime("%B %d, %Y") %>
    <% else %>
      N/A (no expiration date on item)
    <% end %>
    <div style="font-size: 8pt; font-weight: 400; margin-top: 2mm;">
      (One week after item end date)
    </div>
  </div>
</article>
