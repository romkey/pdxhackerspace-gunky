<%= form_with(
  model: item,
  class: "needs-validation",
  data: {
    controller: "photo-ai",
    photo_ai_upload_url_value: preview_description_items_path
  }
) do |f| %>
  <% if item.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(item.errors.count, "error") %> prevented this item from being saved:</h5>
      <ul class="mb-0">
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "What is this item? Leave blank and the AI agent will describe it from the photo.", data: { photo_ai_target: "description" } %>
  </div>

  <div class="mb-3" data-controller="location-picker">
    <%= f.label :location, class: "form-label" %>
    <%= f.text_field :location, class: "form-control", placeholder: "Where is it?", data: { location_picker_target: "field" } %>
    <% if locations.any? %>
      <div class="mt-2 d-flex flex-wrap gap-1">
        <% locations.each do |loc| %>
          <button type="button" class="btn btn-sm btn-outline-secondary"
                  data-action="location-picker#pick"
                  data-location="<%= loc.name %>">
            <%= loc.name %>
          </button>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :photo, class: "form-label" %>
    <div class="mb-2">
      <%= f.label :photo, "Take Photo", class: "form-label small text-muted" %>
      <%= f.file_field :photo, class: "form-control", accept: "image/*", capture: "environment", data: { photo_ai_target: "photoInput", action: "change->photo-ai#selected" } %>
    </div>
    <div>
      <%= f.label :photo, "Upload Photo", class: "form-label small text-muted" %>
      <%= f.file_field :photo, class: "form-control", accept: "image/*", data: { photo_ai_target: "photoInput", action: "change->photo-ai#selected" } %>
    </div>
    <div class="form-text" data-photo-ai-target="status"></div>
    <div class="mt-2 <%= "d-none" unless item.photo.attached? %>" data-photo-ai-target="previewWrapper">
      <img
        data-photo-ai-target="preview"
        class="rounded"
        style="max-width: 200px; max-height: 150px;"
        alt="Photo preview"
        <% if item.photo.attached? %>
          src="<%= url_for(item.photo.variant(resize_to_fill: [200, 150])) %>"
        <% end %>
      >
    </div>
    <% if item.photo.attached? %>
      <div class="form-text mt-1">Current photo</div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :expiration_date, class: "form-label" %>
    <%= f.date_field :expiration_date, class: "form-control", value: item.expiration_date || 7.days.from_now.to_date %>
    <div class="form-text">When the poll expires. Defaults to 1 week from today.</div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", items_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
