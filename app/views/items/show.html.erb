<%= turbo_stream_from "item_#{@item.id}" %>

<div class="row">
  <div class="col-lg-6">
    <% if @item.photo.attached? %>
      <%= image_tag @item.photo.variant(resize_to_limit: [800, 600]), class: "img-fluid rounded mb-3", alt: @item.display_description.truncate(50) %>
    <% else %>
      <div class="bg-secondary rounded d-flex align-items-center justify-content-center mb-3" style="height: 300px;">
        <span class="text-white-50 fs-3">No photo</span>
      </div>
    <% end %>
  </div>

  <div class="col-lg-6">
    <%= render "items/description", item: @item %>

    <table class="table">
      <tbody>
        <tr>
          <th>Location</th>
          <td><%= @item.location.presence || "Not specified" %></td>
        </tr>
        <tr>
          <th>Disposition</th>
          <td>
            <span class="badge <%= disposition_badge_class(@item.disposition) %> fs-6"><%= @item.disposition.capitalize %></span>
            <% if @item.expired? && @item.pending? %>
              <span class="badge bg-warning text-dark fs-6">Expired</span>
            <% end %>
          </td>
        </tr>
        <% if @item.claimed_by.present? %>
          <tr>
            <th>Claimed by</th>
            <td><%= @item.claimed_by %></td>
          </tr>
        <% end %>
        <tr>
          <th>Expires</th>
          <td><%= @item.expiration_date&.strftime("%B %d, %Y") || "N/A" %></td>
        </tr>
        <tr>
          <th>Created</th>
          <td><%= @item.created_at.strftime("%B %d, %Y at %l:%M %p") %></td>
        </tr>
        <tr>
          <th>Slack</th>
          <td><%= @item.posted_to_slack? ? "Posted" : "Not posted" %></td>
        </tr>
      </tbody>
    </table>

    <% if @item.votes.any? %>
      <h5>Votes</h5>
      <div class="mb-3">
        <% Vote.choices.each_key do |choice| %>
          <% count = @item.votes.where(choice: choice).count %>
          <% next if count.zero? %>
          <div class="d-flex align-items-center mb-1">
            <span class="badge <%= vote_badge_class(choice) %> me-2"><%= choice.capitalize %></span>
            <span class="fw-bold me-2"><%= count %></span>
            <small class="text-muted">
              (<%= @item.voter_usernames_for(choice).join(", ") %>)
            </small>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @item.pending? %>
      <hr>
      <h5>Resolve this item</h5>
      <%= form_with url: resolve_item_path(@item), method: :patch, class: "mb-3" do |f| %>
        <div class="row g-2 align-items-end">
          <div class="col-auto">
            <%= f.label :disposition, class: "form-label" %>
            <%= f.select :disposition, [["Mine", "mine"], ["Foster", "foster"], ["Kill", "kill"]], {}, class: "form-select" %>
          </div>
          <div class="col-auto">
            <%= f.label :claimed_by, "Claimed by", class: "form-label" %>
            <%= f.text_field :claimed_by, class: "form-control", placeholder: "Name (for Mine)" %>
          </div>
          <div class="col-auto">
            <%= f.submit "Resolve", class: "btn btn-success" %>
          </div>
        </div>
      <% end %>
    <% end %>

    <div class="mt-3 d-flex flex-wrap gap-2">
      <%= link_to "Print receipt",
            print_item_path(@item),
            class: "btn btn-outline-dark btn-sm",
            target: "_blank",
            rel: "noopener" %>
      <%= link_to "Edit", edit_item_path(@item), class: "btn btn-outline-secondary btn-sm" %>
      <% if @item.photo.attached? && AgentSetting.enabled? %>
        <%= button_to "AI Describe", describe_item_path(@item), method: :post, class: "btn btn-outline-info btn-sm" %>
      <% end %>
      <%= link_to "Back", items_path, class: "btn btn-outline-secondary btn-sm" %>
      <%= button_to "Delete", @item, method: :delete, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Are you sure?" } %>
    </div>
  </div>
</div>
