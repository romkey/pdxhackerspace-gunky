<h2>Settings: Thermal receipt printer</h2>

<div class="row">
  <div class="col-md-8">
    <%= form_with(model: @print_setting, url: settings_print_path, method: :patch) do |f| %>
      <% if @print_setting.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @print_setting.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :cups_queue, "CUPS printer queue", class: "form-label" %>
        <%= f.text_field :cups_queue, class: "form-control", placeholder: "e.g. Thermal_TSP100" %>
        <div class="form-text">
          Name shown by <code>lpstat -p</code> or <code>lpstat -a</code> — passed to <code>lp -d</code>.
          Leave blank until the queue exists on the host (or container with CUPS client + <code>CUPS_SERVER</code>).
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :paper_width_mm, "Paper width", class: "form-label" %>
        <%= f.select :paper_width_mm, PrintSetting::ALLOWED_PAPER_WIDTHS.map { |w| [ "#{w} mm", w ] }, {}, class: "form-select" %>
        <div class="form-text">Used for PDF page width sent to the printer.</div>
      </div>

      <div class="alert alert-secondary small mb-4">
        <strong>Printing.</strong> Item receipts are generated as a PDF and submitted with the system
        <code>lp</code> command. Each item is one PDF page so drivers that cut after each page still work.
        The app image installs <code>cups-client</code>; point CUPS at your server if the app runs in Docker
        (e.g. <code>CUPS_SERVER</code> in the environment).
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Save", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
