<h2>Settings: Thermal receipt printer</h2>

<div class="row">
  <div class="col-md-8">
    <%= form_with(model: @print_setting, url: settings_print_path, method: :patch) do |f| %>
      <% if @print_setting.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @print_setting.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :thermal_printer_name, "Printer name (reference)", class: "form-label" %>
        <%= f.text_field :thermal_printer_name, class: "form-control", placeholder: "e.g. Star TSP143III USB" %>
        <div class="form-text">
          For your own notes. The browser print dialog still asks which printer to use—pick this device there.
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :paper_width_mm, "Paper width", class: "form-label" %>
        <%= f.select :paper_width_mm, PrintSetting::ALLOWED_PAPER_WIDTHS.map { |w| [ "#{w} mm", w ] }, {}, class: "form-select" %>
        <div class="form-text">Common receipt rolls are 58&nbsp;mm or 80&nbsp;mm wide.</div>
      </div>

      <div class="alert alert-secondary small mb-4">
        <strong>Auto-cut between items.</strong>
        “Print all completed” lays out each item as its own print page. Many thermal drivers can
        <strong>cut after each page</strong> (wording varies: “Cut per page”, “Document cut”, etc.).
        Enable that for your printer so one physical receipt prints per item. Pure browser printing cannot send raw ESC/POS
        (e.g. <code>GS V 0</code>); the page break is the reliable hook for drivers.
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Save", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
