<h2>Edit Location</h2>

<div class="row">
  <div class="col-md-6">
    <%= form_with(model: @location, url: settings_location_path(@location)) do |f| %>
      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control #{'is-invalid' if @location.errors[:name].any?}", required: true %>
        <% if @location.errors[:name].any? %>
          <div class="invalid-feedback"><%= @location.errors[:name].first %></div>
        <% end %>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Save", class: "btn btn-primary" %>
        <%= link_to "Cancel", settings_locations_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
