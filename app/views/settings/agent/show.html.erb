<h2>Settings: AI Agent</h2>

<div class="row">
  <div class="col-md-8">
    <%= form_with(model: @agent_setting, url: settings_agent_path, method: :patch) do |f| %>
      <% if @agent_setting.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @agent_setting.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3 form-check form-switch">
        <%= f.check_box :enabled, class: "form-check-input", role: "switch" %>
        <%= f.label :enabled, "Enable AI agent", class: "form-check-label" %>
        <div class="form-text">When enabled, uploading a photo with no description will trigger the AI to describe it.</div>
      </div>

      <div class="mb-3">
        <%= f.label :ollama_url, "Ollama URL", class: "form-label" %>
        <%= f.text_field :ollama_url, class: "form-control", placeholder: "http://localhost:11434" %>
        <div class="form-text">The base URL of your Ollama instance.</div>
      </div>

      <div class="mb-3">
        <%= f.label :ollama_model, "Model", class: "form-label" %>
        <%= f.text_field :ollama_model, class: "form-control", placeholder: "llava" %>
        <div class="form-text">A vision-capable model (e.g. llava, llava-llama3, bakllava).</div>
      </div>

      <div class="mb-3">
        <%= f.label :prompt, class: "form-label" %>
        <%= f.text_area :prompt, class: "form-control", rows: 4 %>
        <div class="form-text">The prompt sent to the model along with the photo.</div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Save", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
