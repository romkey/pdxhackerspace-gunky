#!/usr/bin/env bash
set -euo pipefail

# One-time OS packages for native gems (pg, bootsnap, ruby-vips, etc.).
# Marker lives on the bundle volume so it persists across runs.
MARKER="${BUNDLE_PATH:-/usr/local/bundle}/.gunky-test-apt-installed"
if [[ ! -f "${MARKER}" ]]; then
  apt-get update -qq
  DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    git \
    libpq-dev \
    libvips-dev \
    libyaml-dev \
    nodejs \
    npm \
    pkg-config \
    postgresql-client \
    >/dev/null
  touch "${MARKER}"
fi

# Markers created before Node was added skip the block above; ensure npm exists.
if ! command -v npm >/dev/null 2>&1; then
  apt-get update -qq
  DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends nodejs npm >/dev/null
fi

bundle check || bundle install -j"$(nproc)"

# cssbundling-rails hooks db:test:prepare → css:build (needs node_modules).
if [[ -f package-lock.json ]]; then
  LOCK_HASH="$(sha256sum package-lock.json | awk '{ print $1 }')"
  NPM_MARKER="${BUNDLE_PATH:-/usr/local/bundle}/.gunky-npm-${LOCK_HASH}"
  if [[ ! -f "${NPM_MARKER}" ]]; then
    npm ci
    touch "${NPM_MARKER}"
  fi
fi

exec "$@"
